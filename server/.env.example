# ─── Arc Testnet (Canteen-hosted) ─────────────────────────────
# Get your personalized URL via the official CLI:
#   uv tool install git+https://github.com/the-canteen-dev/ARC-cli.git
#   arc-canteen login            # auth with GitHub
#   arc-canteen rpc-url --export # prints export RPC="..."
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# ─── USDC + Gateway on Arc Testnet ───────────────────────────
# From Circle's use-arc / use-gateway skills (testnet addresses)
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000
GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# ─── Circle ──────────────────────────────────────────────────
# Circle API key + App ID from https://console.circle.com
CIRCLE_API_KEY=
CIRCLE_APP_ID=

# ─── x402 / Gateway facilitator (testnet) ────────────────────
FACILITATOR_URL=https://gateway-api-testnet.circle.com
NETWORK_ID=eip155:5042002

# ─── Canteen faucet (testnet USDC) ───────────────────────────
FAUCET_URL=https://faucet.circle.com

# ─── Server config ───────────────────────────────────────────
PORT=3001
PUBLIC_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
DB_PATH=./pazzera.db
TRACKS_DIR=./tracks

# Platform fee (basis points). 0 = free.
PLATFORM_FEE_BPS=0