# ─── Arc Testnet (Canteen-hosted) ─────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# ─── USDC + Gateway on Arc Testnet ───────────────────────────
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000
GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# ─── Circle (User-Controlled Wallets) ─────────────────────────
# Get from https://console.circle.com → Wallets → User Controlled → Keys
CIRCLE_API_KEY=
CIRCLE_APP_ID=

# ─── x402 / Gateway facilitator (testnet) ────────────────────
FACILITATOR_URL=https://gateway-api-testnet.circle.com
NETWORK_ID=eip155:5042002

# ─── Canteen faucet (testnet USDC) ───────────────────────────
FAUCET_URL=https://faucet.circle.com

# ─── Server config ───────────────────────────────────────────
PORT=3001
PUBLIC_BASE_URL=https://pazzera.com
DB_PATH=./pazzera.db
TRACKS_DIR=./tracks

# JWT secret for our app's session cookies. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-prod

# Platform fee (basis points). 0 = free.
PLATFORM_FEE_BPS=0

# Set to 'production' in deploy. Affects cookie 'secure' flag.
NODE_ENV=production
# ─── NEW: production hardening ─────────────────────────────
# AES-256-GCM key for encrypting Circle user tokens at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Comma-separated allowed CORS origins. Defaults to common dev + prod hosts.
ALLOWED_ORIGINS=https://pazzera.com,https://www.pazzera.com,http://localhost:5173,http://localhost:3001

# Email (transactional). Leave blank to use ethereal.email (hackathon mode).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Pazzera <noreply@pazzera.com>

# Upload storage directory (avatars, track covers)
UPLOADS_DIR=./uploads

# ─── LLM (for Fan Agent, Curator Agent, Royalty Splitter Agent) ────
# OpenAI-compatible API. Set LLM_API_KEY to your provider's key.
# Examples:
#   - FreeModel.dev (free, OpenAI-compatible): https://freemodel.dev
#   - OpenAI: https://api.openai.com
#   - MiniMax (https://platform.minimax.io) — base URL https://api.minimax.chat/v1
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=abab6.5s-chat
