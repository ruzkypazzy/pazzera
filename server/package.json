{
  "name": "pazzera-server",
  "version": "0.1.0",
  "description": "x402 backend for Pazzera — pay-per-listen for indie artists on Arc testnet",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
