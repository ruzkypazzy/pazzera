  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.2.0",
    "@circle-fin/user-controlled-wallets": "^10.7.1",
    "@circle-fin/w3s-pw-web-sdk": "^1.1.11",
    "@x402/core": "^2.16.0",
    "@x402/evm": "^2.16.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
