# Circle App ID (from console.circle.com > Wallets > User Controlled > Configurator)
VITE_PAZZERA_APP_ID=

# Backend URL — leave empty in production (same-origin via /api proxy)
# In dev, set to http://localhost:3001
VITE_PAZZERA_API=

# Arc Testnet RPC (MetaMask fallback chain-add)
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network