# Circle App ID (from console.circle.com > Wallets > User Controlled > Configurator)
PAZZERA_APP_ID=

# Backend URL (the Vite dev server proxies /api to this anyway, but the
# frontend also reads this for absolute URLs in some places).
PAZZERA_API=http://localhost:3001

# Arc Testnet RPC (for MetaMask fallback chain-add)
ARC_RPC_URL=https://rpc.testnet.arc.network